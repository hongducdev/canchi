{
    "expo": {
        "name": "Can Chi",
        "slug": "canchi",
        "version": "1.3.1",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "canchi",
        "userInterfaceStyle": "automatic",
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.canchi.app",
            "infoPlist": {
                "CFBundleDisplayName": "Can Chi"
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#C23B22"
            },
            "package": "com.canchi.app",
            "permissions": [
                "android.permission.INTERNET",
                "android.permission.REQUEST_INSTALL_PACKAGES"
            ]
        },
        "web": {
            "bundler": "metro",
            "output": "single",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-font",
            "expo-asset",
            "expo-notifications",
            [
                "@react-native-google-signin/google-signin",
                {
                    "iosUrlScheme": "com.googleusercontent.apps.canchi-placeholder"
                }
            ],
            [
                "expo-splash-screen",
                {
                    "image": "./assets/splash-icon.png",
                    "resizeMode": "contain",
                    "backgroundColor": "#0F1419",
                    "imageWidth": 128
                }
            ],
            "expo-status-bar",
            [
                "react-native-android-widget",
                {
                    "widgets": [
                        {
                            "name": "DayLore",
                            "label": "Lời hay · Can Chi",
                            "description": "Ngày dương/âm và lời hay hoặc tên lễ",
                            "minWidth": "250dp",
                            "minHeight": "110dp",
                            "targetCellWidth": 4,
                            "targetCellHeight": 2,
                            "resizeMode": "horizontal|vertical",
                            "previewImage": "./assets/widget-preview/day-lore.png",
                            "updatePeriodMillis": 1800000
                        },
                        {
                            "name": "MonthSmall",
                            "label": "Tháng · Can Chi",
                            "description": "Lưới tháng dương/âm",
                            "minWidth": "110dp",
                            "minHeight": "110dp",
                            "targetCellWidth": 2,
                            "targetCellHeight": 2,
                            "resizeMode": "horizontal|vertical",
                            "previewImage": "./assets/widget-preview/month-small.png",
                            "updatePeriodMillis": 1800000
                        },
                        {
                            "name": "DateMinimal",
                            "label": "Ngày · Can Chi",
                            "description": "Ngày lớn và âm lịch",
                            "minWidth": "110dp",
                            "minHeight": "110dp",
                            "targetCellWidth": 2,
                            "targetCellHeight": 2,
                            "resizeMode": "horizontal|vertical",
                            "previewImage": "./assets/widget-preview/date-minimal.png",
                            "updatePeriodMillis": 1800000
                        },
                        {
                            "name": "Combo",
                            "label": "Ngày + Tháng · Can Chi",
                            "description": "Ngày hôm nay và lưới tháng",
                            "minWidth": "250dp",
                            "minHeight": "110dp",
                            "targetCellWidth": 4,
                            "targetCellHeight": 2,
                            "resizeMode": "horizontal|vertical",
                            "previewImage": "./assets/widget-preview/combo.png",
                            "updatePeriodMillis": 1800000
                        },
                        {
                            "name": "DayDetail",
                            "label": "Chi tiết ngày · Can Chi",
                            "description": "Đầy đủ dương/âm, can chi, hoàng đạo hôm nay",
                            "minWidth": "250dp",
                            "minHeight": "250dp",
                            "targetCellWidth": 4,
                            "targetCellHeight": 4,
                            "resizeMode": "horizontal|vertical",
                            "previewImage": "./assets/widget-preview/day-detail.png",
                            "updatePeriodMillis": 1800000
                        }
                    ]
                }
            ],
            "@react-native-community/datetimepicker"
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}
